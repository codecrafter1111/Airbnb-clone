<% layout("/layouts/boilerPlate") %>
<div class="container ">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a href="/listings" class="back-link">All Listings</a>
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="card-title text-center mb-4">Create a New Listing</h1>
                    
                    <form class="needs-validation" method="POST" action="/listings" novalidate enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="title">Title *</label>
                            <input 
                                type="text" 
                                id="title"
                                name="listing[title]" 
                                class="form-control"
                                required 
                                placeholder="Give your listing a catchy title"
                            >
                            <div class="invalid-feedback">Please provide a title.</div>
                            <div class="valid-feedback">Title looking good</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="description">Description *</label>
                            <textarea 
                                id="description"
                                name="listing[description]" 
                                class="form-control"
                                rows="4"
                                required
                                placeholder="Describe what makes your place special"
                            ></textarea>
                            <div class="invalid-feedback">Please provide a description.</div>
                        </div>

            
                        <div class="mb-3">
                            <label class="form-label" for="image">Upload Listing Image</label>
                            <input 
                                type="file" 
                                id="image"
                                name="listing[image]" 
                                class="form-control"
                                required
                            >
                            <div class="form-text">Paste a link to a high-quality image</div>
                            <div class="invalid-feedback">Please provide an image URL.</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="price">Price per night *</label>
                                <input 
                                    type="number" 
                                    id="price"
                                    name="listing[price]" 
                                    class="form-control"
                                    required  
                                    placeholder="₹ 1000"                                 
                                >
                                <div class="invalid-feedback">Please provide a valid price.</div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="location">Location *</label>
                                <input 
                                    type="text" 
                                    id="location"
                                    name="listing[location]" 
                                    class="form-control"
                                    required  
                                    placeholder="City or area"
                                >
                                <div class="invalid-feedback">Please provide a location.</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="country">Country *</label>
                                <input 
                                    type="text" 
                                    id="country"
                                    name="listing[country]" 
                                    class="form-control"
                                    required  
                                    placeholder="Country name"
                                >
                                <div class="invalid-feedback">Please provide a country.</div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label" for="day">Listing Type *</label>
                            <select 
                                id="day"
                                name="listing[day]" 
                                class="form-select"  
                                required  
                            >
                                <option value="">Select type</option>
                                <option value="day">Day Time</option>
                                <option value="night">Night Time</option>
                            </select>
                            <div class="invalid-feedback">Please select a listing type.</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Create Listing</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

