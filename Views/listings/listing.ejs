<div class="cards-grid">
    <% for( let listing of alllistings ) { %>
        <a href="/listings/<%= listing._id %>" class="card-link">
            <div class="property-card">
                <div class="card-image-container">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="card-image">
                    <button class="card-wishlist">
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: rgba(0, 0, 0, 0.5); height: 24px; width: 24px; stroke: white; stroke-width: 2; overflow: visible;">
                            <path d="m16 28c7-4.733 14-10 14-17 0-1.792-.683-3.583-2.05-4.95-1.367-1.366-3.158-2.05-4.95-2.05-1.791 0-3.583.684-4.949 2.05l-2.051 2.051-2.05-2.051c-1.367-1.366-3.158-2.05-4.95-2.05-1.791 0-3.583.684-4.949 2.05-1.367 1.367-2.051 3.158-2.051 4.95 0 7 7 12.267 14 17z"></path>
                        </svg>
                    </button>
                </div>
                <div class="card-content">
                    <div class="card-header">
                        <h3 class="card-location"><%= listing.location %>, <%= listing.country %></h3>
                        <div class="card-rating">
                            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; height: 12px; width: 12px; fill: currentColor;">
                                <path d="M15.094 1.579l-4.124 8.885-9.86 1.27a1 1 0 0 0-.542 1.736l7.293 6.565-1.965 9.852a1 1 0 0 0 1.483 1.061L16 25.951l8.625 4.997a1 1 0 0 0 1.482-1.06l-1.965-9.853 7.293-6.565a1 1 0 0 0-.541-1.735l-9.86-1.271-4.127-8.885a1 1 0 0 0-1.814 0z" fill-rule="evenodd"></path>
                            </svg>
                            <span class="rating-text"><%= listing.rating %></span>
                        </div>
                    </div>
                    <p class="card-description"><%= listing.title %></p>
                    <p class="card-dates">Jan 15 – 20</p>
                    <div class="card-price">
                        <span class="price-amount">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
                        <span class="price-period"><%= listing.day %></span>
                    </div>
                </div>
            </div>
        </a>
    <% } %>
</div>

